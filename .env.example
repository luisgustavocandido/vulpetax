# Copie para .env e preencha os valores.
# cp .env.example .env

# Banco de dados (PostgreSQL)
# Ex.: postgresql://usuario:senha@localhost:5432/nome_do_banco
DATABASE_URL="postgresql://usuario:senha@localhost:5433/nome_do_banco"

# Auth (NextAuth)
# Gerar NEXTAUTH_SECRET: openssl rand -base64 32
PASSCODE=sua_senha_passcode
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Dashboard Financeiro (CEO) — /dashboard-financeiro
# FINANCE_DASHBOARD_SECRET: opcional; se não definido, usa PASSCODE para assinar o cookie.
FINANCE_DASHBOARD_PASSWORD=senha_ceo
# FINANCE_DASHBOARD_SECRET=opcional-secret-para-cookie

# Sync TAX Form via Google Sheets (opcional)
CRON_SECRET=mesmo_ou_outro_secret
GOOGLE_SERVICE_ACCOUNT_EMAIL=seu-email@projeto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=id_do_spreadsheet
GOOGLE_SHEETS_GID=id_da_aba

# Sync Pós-Venda LLC (opcional)
POSVENDA_SHEETS_SPREADSHEET_ID=id_do_spreadsheet
POSVENDA_SHEETS_GID=id_da_aba

# Gotenberg (PDF) - opcional
GOTENBERG_URL=http://localhost:3001
